# SQLite database (relative to prisma folder)
DATABASE_URL="file:./dev.db"

# Comma-separated emails allowed to sign in to the dashboard
ALLOWED_EMAILS="ebenezer.kwofie@mcgill.ca"

# First admin user created on seed (must also appear in ALLOWED_EMAILS)
SEED_ADMIN_EMAIL="ebenezer.kwofie@mcgill.ca"

# Shared password for dashboard login (all allowlisted users use this)
APP_PASSWORD="change-me-in-production"

# JWT signing secret (min 16 characters)
SESSION_SECRET="replace-with-a-long-random-string"

# Public URL for invite links (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Email (Phase 3) — leave SMTP_HOST empty to log notifications without sending ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ebenezer.kwofie@mcgill.ca"

# Who receives alerts when a faculty form is submitted
NOTIFY_TO="ebenezer.kwofie@mcgill.ca"
NOTIFY_CC=""

# Send confirmation email to the faculty member who submitted (true/false)
NOTIFY_RESPONDENT="false"
