# SQLite database (relative to project root for dev; absolute in production)
DATABASE_URL="file:./dev.db"

# Comma-separated emails allowed to sign in to the dashboard
ALLOWED_EMAILS="ebenezer.kwofie@mcgill.ca"

# First admin user created on seed (must also appear in ALLOWED_EMAILS)
SEED_ADMIN_EMAIL="ebenezer.kwofie@mcgill.ca"

# Shared password for dashboard login (all allowlisted users use this)
APP_PASSWORD="change-me-in-production"

# JWT signing secret (min 16 characters)
SESSION_SECRET="replace-with-a-long-random-string"

# Public URL used to build invite links (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# This deployment does NOT use SMTP. All outbound mail is composed in the
# operator's McGill Outlook via mailto links generated by the dashboard.
# See dashboard /settings for details.
