generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AllowedUser {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("viewer")
  createdAt DateTime @default(now())
}

model ReportingPeriod {
  id          String       @id @default(cuid())
  label       String
  slug        String       @unique
  // Quarterly cadence for Partner Narrative Report alignment.
  // programYear: 1, 2, 3, ... (year of the Nkabom programme, not calendar year)
  // quarter: 1..4
  // reportKey: canonical sortable identifier, e.g. "Y2Q3"; unique when set
  programYear Int?
  quarter     Int?
  reportKey   String?      @unique
  startDate   String?
  endDate     String?
  status      String       @default("open")
  createdAt   DateTime     @default(now())
  invites     FormInvite[]
  submissions Submission[]
}

model FormInvite {
  id          String          @id @default(cuid())
  token       String          @unique
  periodId    String
  period      ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  email       String?
  fullName    String?
  faculty     String?
  expiresAt   DateTime?
  submittedAt DateTime?
  createdAt   DateTime        @default(now())
  submission  Submission?

  @@index([periodId])
}

model Submission {
  id                         String          @id @default(cuid())
  periodId                   String
  inviteId                   String?         @unique
  fullName                   String
  email                      String
  faculty                    String
  department                 String
  position                   String
  submissionDate             String
  resourcesNeeded            String?
  collaborationOpportunities String?
  challengesBarriers         String?
  // Phase 1e: maps to the Partner Narrative Report's "Implementation
  // Learning" section. Free-text lessons learned during the reporting
  // period.
  lessonsLearned             String?
  outcomesAchievements       String?
  otherInformation           String?
  submittedAt                DateTime        @default(now())
  period                     ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  invite                     FormInvite?     @relation(fields: [inviteId], references: [id])
  activities                 Activity[]
  challenges                 Challenge[]
  successStories             SuccessStory[]

  @@index([periodId])
  @@index([email])
}

// Phase 4: participant-centred Success Stories per the Partner Narrative
// Report's Section 6. The consent flag is the docx's signature checkbox;
// when false, participantName MUST be NULL (enforced at the application
// layer in submissions.ts and validation.ts). Without consent the story is
// still useful internally but is suppressed from any outward-facing
// communication or report output.
model SuccessStory {
  id              String     @id @default(cuid())
  submissionId    String
  // Participant name is set only when consent is true; never persist a name
  // without explicit consent.
  participantName String?
  programActivity String
  location        String?
  story           String
  outcomes        String?
  photoUrl        String?
  consent         Boolean    @default(false)
  orderIndex      Int        @default(0)
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

// Phase 2: structured challenges per the Partner Narrative Report template's
// "Programme Challenges and Barriers for Success" section. The report wants
// per-pillar tables of {Challenge, Contributing Factor, Response Approach};
// we model each row as a Challenge tied to its parent Submission and tagged
// with the relevant pillar (Education / Access / Entrepreneurship /
// Networking / Other). pillar uses the same string vocabulary as
// ActivityTheme.theme.
model Challenge {
  id                  String     @id @default(cuid())
  submissionId        String
  pillar              String
  challenge           String
  contributingFactor  String?
  responseApproach    String?
  orderIndex          Int        @default(0)
  submission          Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([pillar])
}

model Activity {
  id                 String          @id @default(cuid())
  submissionId       String
  title              String
  status             String
  // Phase 1c: report-aligned descriptors.
  // activityType: Training / Workshop / Meeting / Event / Course / Mentorship / Outreach / Research / Other
  // location:    free text, e.g. "Kumasi" or "Accra, Tamale, Kumasi"
  // localeType:  Rural / Urban / Peri-Urban / Mixed
  activityType       String?
  location           String?
  localeType         String?
  // Phase 1d: participant disaggregation feeding the Overall Indicator
  // Performance table. All counts are nullable: NULL means "not reported",
  // 0 means "explicitly zero". Locale split (Rural/Urban/Peri-Urban) is
  // derived from Activity.localeType rather than duplicated as counts.
  outreachCount             Int?
  participantsTotal         Int?
  participantsYouth         Int?
  participantsWomen         Int?
  participantsDisability    Int?
  participantsRefugeeIdp    Int?
  participantsYiW           Int?
  participantsYiWWomen      Int?
  description        String?
  startDate          String?
  endDate            String?
  // Phase 3: partner type classifier feeding the Collaboration Update
  // section. Values: Academic / Industry / Community Organization /
  // Government / Other.
  partnerType        String?
  partnerInstitution String?
  contactName        String?
  contactEmail       String?
  outputs            String?
  submission         Submission      @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  themes             ActivityTheme[]
  collaborators      Collaborator[]

  @@index([submissionId])
}

model ActivityTheme {
  activityId String
  theme      String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@id([activityId, theme])
}

model Collaborator {
  id         String   @id @default(cuid())
  activityId String
  name       String
  faculty    String?
  email      String?
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
}

model PillarTarget {
  id        String   @id @default(cuid())
  periodKey String
  pillar    String
  target    Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([periodKey, pillar])
}
